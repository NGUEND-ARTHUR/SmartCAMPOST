# Put these in your backend environment (do NOT commit real secrets)
MTN_CONSUMER_KEY=
MTN_CONSUMER_SECRET=
# Optional: MTN token and init URLs (sandbox/production)
# Example sandbox token URL: https://sandbox.momodeveloper.mtn.com/collection/token/
MTN_TOKEN_URL=
MTN_INIT_URL=

# CamerPay Mobile Money (OM + MTN)
PAYMENT_GATEWAY=camerpay
CAMERPAY_API_TOKEN=
CAMERPAY_HMAC_SECRET=
CAMERPAY_INIT_URL=https://camerpay.biz/api/payment/initiate
CAMERPAY_VERIFY_URL=https://camerpay.biz/api/payment/{externalRef}/status
