# SmartCAMPOST — Environment Variables Template for Production
# Copy this file to .env.prod and fill in the real values.
# NEVER commit .env.prod to version control.

# ─── Database ────────────────────────────────────────────────────────────────
MYSQL_ROOT_PASSWORD=<strong_root_password>
MYSQL_PASSWORD=<strong_app_password>

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=<strong_redis_password>

# ─── JWT ──────────────────────────────────────────────────────────────────────
# Must be at least 32 characters. Generate with: openssl rand -hex 32
SMARTCAMPOST_JWT_SECRET=<generate_with_openssl_rand_hex_32>
JWT_EXPIRATION_HOURS=8
REFRESH_TOKEN_DAYS=7

# ─── Google OAuth ─────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=428837425425-hvbdljimv02i2kapehk51haap4160v68.apps.googleusercontent.com

# ─── Twilio SMS ───────────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=<your_twilio_account_sid>
TWILIO_AUTH_TOKEN=<your_twilio_auth_token>
TWILIO_PHONE_NUMBER=<your_twilio_phone_number>

# ─── OpenAI ───────────────────────────────────────────────────────────────────
OPENAI_API_KEY=<your_openai_api_key>

# ─── MTN MoMo ────────────────────────────────────────────────────────────────
MTN_SUBSCRIPTION_KEY=<your_mtn_subscription_key>
MTN_BASE_URL=https://proxy.momoapi.mtn.com

# ─── Orange Money ────────────────────────────────────────────────────────────
ORANGE_CLIENT_ID=<your_orange_client_id>
ORANGE_CLIENT_SECRET=<your_orange_client_secret>

# ─── CORS ────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins (no trailing slash)
CORS_ALLOWED_ORIGINS=https://smartcampost.vercel.app,https://smartcampost-frontend.vercel.app

# ─── Feature Flags ────────────────────────────────────────────────────────────
RATE_LIMIT_ENABLED=true
SWAGGER_ENABLED=false
